  },
  "dependencies": {
    "pg": "^8.0.0",
    "chalk": "^5.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/pg": "^8.0.0",
    "@types/node": "^22.0.0"
  }
