  "description": "PostgreSQL EXPLAIN ANALYZE in your terminal. The only CLI/MCP alternative to web-based visualizers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pg-explain": "./dist/cli.js",
